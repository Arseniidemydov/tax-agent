# Copy this to .env.local for local testing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_MS=120000
ANTHROPIC_VERIFIER_TIMEOUT_MS=60000
ANTHROPIC_VERIFIER_BATCH_SIZE=6

# Verifier tuning knobs (defaults baked in; override only if needed).
OPENAI_VERIFIER_MIN_CLUSTER_AMOUNT=750
OPENAI_VERIFIER_AUTO_APPLY_CONFIDENCE=0.88
VERIFIER_AMA_FALLBACK_CONFIDENCE=0.55
STRICT_REVIEW_MIN_CLUSTER_AMOUNT=250
